{
  "name": "docstring_check",
  "description": "Check documentation coverage: find functions, classes, and modules missing docstrings in Python code",
  "input_schema": {
    "type": "object",
    "properties": {
      "code": {
        "type": "string",
        "description": "Python source code to check"
      },
      "file_path": {
        "type": "string",
        "description": "Path to a Python file (alternative to code)"
      },
      "ignore_private": {
        "type": "boolean",
        "description": "Ignore private functions/methods (starting with _)",
        "default": true
      }
    }
  },
  "execution": {
    "type": "python",
    "entry": "handler.py"
  }
}
